<!DOCTYPE html>

<title>Category</title>

{% block body %}
    <h1>Category: {{ category.title }}</h1>

    <h2>Operations</h2>
    <ul>
        {% for operation in category.operations %}
            <li>
                <strong>{{ operation.label }}</strong>: {{ operation.value }} ({{ operation.date|date('Y-m-d') }})
            </li>
        {% else %}
            <li>No operations found for this category.</li>
        {% endfor %}
    </ul>

    <a href="{{ path('app_category_index') }}">Back to list</a>
{% endblock %}
