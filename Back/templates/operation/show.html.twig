<!DOCTYPE html>

<title>Operation</title>

{% block body %}
    <h1>Operation</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ operation.id }}</td>
            </tr>
            <tr>
                <th>Label</th>
                <td>{{ operation.label }}</td>
            </tr>
            <tr>
                <th>Value</th>
                <td>{{ operation.value }}</td>
            </tr>
            <tr>
                <th>Date</th>
                <td>{{ operation.date ? operation.date|date('Y-m-d') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_operation_index') }}">back to list</a>

    <a href="{{ path('app_operation_edit', {'id': operation.id}) }}">edit</a>

    {{ include('operation/_delete_form.html.twig') }}
{% endblock %}
